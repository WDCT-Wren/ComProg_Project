<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" styleClass="root" stylesheets="@../StyleSheets/PauseMenu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.group1.GamePackage.UI.Controllers.PauseController">
   <top>
      <Label styleClass="Title" text="Larpathon" BorderPane.alignment="CENTER" />
   </top>
   <center>
      <StackPane BorderPane.alignment="CENTER">
         <children>
            <VBox fx:id="pauseMenu" prefHeight="200.0" prefWidth="100.0" styleClass="menu-container">
               <children>
                  <Button mnemonicParsing="false" onAction="#onResume" styleClass="menu-button" text="Resume" />
                  <Button mnemonicParsing="false" onAction="#onOptions" styleClass="menu-button" text="Options" />
                  <Button mnemonicParsing="false" onAction="#onMainMenu" styleClass="menu-button" text="Return to Main Menu" />
               </children>
            </VBox>
            <VBox fx:id="optionsMenu" prefHeight="200.0" prefWidth="100.0" styleClass="menu-container" visible="false">
               <children>
                  <Button mnemonicParsing="false" onAction="#onPauseMenu" styleClass="menu-button" text="Back" />
                  <Button mnemonicParsing="false" onAction="#onAudio" styleClass="menu-button" text="Audio" />
               </children>
            </VBox>
            <VBox fx:id="audioMenu" prefHeight="200.0" prefWidth="100.0" styleClass="menu-container" visible="false">
               <children>
                  <Label styleClass="sub-title" text="Audio Settings" />
                  <HBox alignment="CENTER" prefHeight="25.0" prefWidth="1261.0">
                     <children>
                        <Label styleClass="sub-title" text="Music Volume" />
                        <Slider fx:id="musicVolumeSlider" max="1.0" prefHeight="14.0" prefWidth="343.0" styleClass="audio-slider" value="50.0" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="25.0" prefWidth="1261.0">
                     <children>
                        <Label styleClass="sub-title" text="Sound Volume" />
                        <Slider fx:id="soundVolumeSlider" prefHeight="14.0" prefWidth="343.0" styleClass="audio-slider" value="50.0" />
                     </children>
                  </HBox>
                  <Button mnemonicParsing="false" onAction="#onOptions" styleClass="menu-button" text="Back" />
               </children>
            </VBox>
         </children>
      </StackPane>
   </center>
</BorderPane>
